---
import Layout from "../layouts/Layout.astro";
import { getServerAuthState } from "../lib/auth-session";

export const prerender = false;

const authState = await getServerAuthState(Astro.request.headers);
---

<Layout
  class="mx-auto mt-10 flex w-full max-w-5xl items-start md:mt-0 md:mb-10 md:items-center lg:mb-[15%]"
  title="CCS Internal Docs | knowledge"
>
  <div
    class="flex w-full flex-col items-start gap-x-6 gap-y-8 px-5 md:px-10 lg:flex-row lg:items-center lg:justify-between"
  >
    <div>
      <span class="text-xs font-extrabold text-blue-600 uppercase">knowledge</span>
      <h1 class="text-4xl font-bold sm:text-6xl lg:mt-2">CCS Internal Docs</h1>
      <p class="mt-2 text-lg lg:mt-4 lg:text-gray-500">CCS のドキュメントサイト</p>
    </div>

    <div class="rounded-lg bg-white lg:border lg:border-neutral-300/60 lg:px-10 lg:py-8 lg:shadow-md">
      {
        authState.user ? (
          <>
            <p class="mb-2 text-xs font-extrabold text-blue-600 uppercase">Signed in as</p>
            <div class="flex items-center gap-3">
              {authState.user.imageUrl && (
                <img alt="" class="flex-none rounded-lg" height="48" src={authState.user.imageUrl} width="48" />
              )}
              <p>{authState.user.name}</p>
            </div>
          </>
        ) : (
          <>
            <p class="text-xs font-extrabold text-blue-600 uppercase">Signed out</p>
            <p class="mt-0.5 lg:mt-2">アクセスするにはサインインが必要です。</p>
            <a
              class="mt-2 inline-flex items-center justify-center rounded-xl bg-[#5865F2] px-6 py-3 font-bold text-white lg:mt-4"
              href="/sign-in"
            >
              Sign in with Discord
            </a>
          </>
        )
      }
    </div>
  </div>
</Layout>
